local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- EVENTS
local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local ColorRemote = Remotes:WaitForChild("UpdateRPColor")
local BioColorRemote = Remotes:WaitForChild("UpdateBioColor")

-- SETTINGS
local BioUpdateFrequency = 0.03
local blinkSpeed = 0.003 -- jitni chahen tezz kar sakte ho

-- VARIABLES
local lastBioUpdate = 0
local Connection
local isBioColorRemoteFunction = BioColorRemote:IsA("RemoteFunction")

-- COLORS
local Colors = {
    Color3.fromRGB(255, 0, 0),      -- سرخ
    Color3.fromRGB(255, 127, 0),    -- سنتری
    Color3.fromRGB(255, 255, 0),    -- پیلا
    Color3.fromRGB(0, 255, 0),      -- سبز
    Color3.fromRGB(0, 0, 255),      -- نیلا
    Color3.fromRGB(75, 0, 130),     -- نیل
    Color3.fromRGB(148, 0, 211),    -- بنفشی
}

-- GUI
local function CreateGUI()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "ColorBlinkGui"
    ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
    ScreenGui.ResetOnSpawn = false

    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0,450,0,150)
    Frame.Position = UDim2.new(0.5,-225,0.5,-75)
    Frame.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Frame.Parent = ScreenGui

    -- CLOSE BUTTON
    local Close = Instance.new("TextButton")
    Close.Size = UDim2.new(0,35,0,35)
    Close.Position = UDim2.new(1,-40,0,5)
    Close.Text = "✖"
    Close.TextScaled = true
    Close.BackgroundColor3 = Color3.fromRGB(200,50,50)
    Close.TextColor3 = Color3.fromRGB(255,255,255)
    Close.BorderSizePixel = 0
    Close.Parent = Frame

    -- COLOR BOX
    local ColorBox = Instance.new("Frame")
    ColorBox.Size = UDim2.new(0,120,0,40)
    ColorBox.Position = UDim2.new(0.5,-60,0,50)
    ColorBox.BackgroundColor3 = Colors[1]
    ColorBox.Parent = Frame

    -- START BUTTON
    local Start = Instance.new("TextButton")
    Start.Size = UDim2.new(0,200,0,35)
    Start.Position = UDim2.new(0.5,10,0,100)
    Start.Text = "Start"
    Start.Parent = Frame

    -- STOP BUTTON
    local Stop = Instance.new("TextButton")
    Stop.Size = UDim2.new(0,200,0,35)
    Stop.Position = UDim2.new(0.5,-210,0,100)
    Stop.Text = "Stop"
    Stop.Parent = Frame

    return ScreenGui, ColorBox, Start, Stop, Close
end

local ScreenGui, ColorBox, StartButton, StopButton, CloseButton = CreateGUI()

-- BLINK LOGIC
local colorIndex = 1
local timer = 0

local function GetNextColor()
    local c = Colors[colorIndex]
    colorIndex += 1
    if colorIndex > #Colors then
        colorIndex = 1
    end
    return c
end

local function StartBlink()
    if Connection then
        Connection:Disconnect()
    end

    _G.ColorBlinkStop = false

    Connection = RunService.Heartbeat:Connect(function(dt)
        if _G.ColorBlinkStop then return end

        timer += dt

        if timer >= blinkSpeed then
            timer = 0
            local NewColor = GetNextColor()

            if ColorBox and ColorBox.Parent then
                ColorBox.BackgroundColor3 = NewColor
            end

            -- SERVER COLOR UPDATE
            pcall(function()
                ColorRemote:FireServer(NewColor)
            end)

            lastBioUpdate += dt
            if lastBioUpdate >= BioUpdateFrequency then
                lastBioUpdate = 0
                pcall(function()
                    if isBioColorRemoteFunction then
                        BioColorRemote:InvokeServer(NewColor)
                    else
                        BioColorRemote:FireServer(NewColor)
                    end
                end)
            end
        end
    end)
end

-- BUTTONS
StartButton.MouseButton1Click:Connect(function()
    StartBlink()
end)

StopButton.MouseButton1Click:Connect(function()
    _G.ColorBlinkStop = true
end)

CloseButton.MouseButton1Click:Connect(function()
    if ScreenGui and ScreenGui.Parent then
        ScreenGui:Destroy()
    end
    print("GUI Closed, Color blink continues in background")
end)

-- AUTO START
StartBlink()
